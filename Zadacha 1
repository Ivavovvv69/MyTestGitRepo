
int number=int.Parse(Console.ReadLine());

if (number > 0)
{
    if (number % 2 == 0)
    {
        Console.WriteLine("Polojitelno chetno");
    }
    else
        Console.WriteLine("Polojitelno nechetno");
}
if (number < 0)
{
    if (number * 2 == 0)
    {
        Console.WriteLine("Otricatelno chetno");
    }
    else
        Console.WriteLine("Otricatelno nechetno");
}
if (number == 0)
{
    Console.WriteLine("Nula");
}
